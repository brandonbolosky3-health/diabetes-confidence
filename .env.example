# Public app URL (no trailing slash). Used in email links and Stripe redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by API routes that need to bypass RLS (cookbook intake,
# consultation forms, Stripe webhook, admin tooling).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_ESSENTIAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=

# ─── Resend (transactional email) ──────────────────────────────────────────
RESEND_API_KEY=
# Optional. Defaults to "Saryn Health <hello@sarynhealth.com>".
# RESEND_FROM_EMAIL="Saryn Health <hello@sarynhealth.com>"
# Where intake notifications (free consultation + pre-consultation form) are
# delivered. Falls back to RESEND_FROM_EMAIL if unset.
ADMIN_NOTIFICATION_EMAIL=

# ─── Anthropic (AI coaching) ───────────────────────────────────────────────
# Required for /api/ai and /api/coaching routes.
ANTHROPIC_API_KEY=

# ─── Admin access ──────────────────────────────────────────────────────────
# Comma-separated list of emails granted /admin access.
ADMIN_EMAILS=

# ─── Cron auth ─────────────────────────────────────────────────────────────
# Shared secret used to authenticate Vercel Cron requests
# (/api/cron/reset-notifications, /api/emails/pre-consultation-reminder).
CRON_SECRET=
